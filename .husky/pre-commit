#!/bin/bash
set -e

echo "🧹 Running lint-staged..."
npx lint-staged

echo "🌾 Running Fallow audit..."
npx fallow audit --base main --gate new-only --dead-code-baseline fallow-baselines/dead-code.json --health-baseline fallow-baselines/health.json --dupes-baseline fallow-baselines/dupes.json --summary --fail-on-issues

echo "🔎 Running typecheck..."
npm run typecheck

echo "🧪 Running tests..."
npm run test
