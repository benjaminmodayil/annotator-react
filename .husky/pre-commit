#!/bin/bash
set -e

base_ref="${FALLOW_BASE_REF:-origin/main}"
if git rev-parse --verify "$base_ref" >/dev/null 2>&1; then
  fallow_base="$(git merge-base HEAD "$base_ref")"
else
  fallow_base="${FALLOW_BASE_REF:-main}"
fi

echo "🧹 Running lint-staged..."
npx lint-staged

echo "🌾 Running Fallow audit..."
npx fallow audit --base "$fallow_base" --summary --fail-on-issues
