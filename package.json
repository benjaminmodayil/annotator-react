{
  "name": "@mikuexe/annotator-react",
  "version": "0.1.2",
  "description": "React overlay for source-aware UI annotations copied into coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "Benjamin Modayil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikuexe/annotator-react.git"
  },
  "homepage": "https://github.com/mikuexe/annotator-react#readme",
  "bugs": {
    "url": "https://github.com/mikuexe/annotator-react/issues"
  },
  "keywords": [
    "react",
    "vite",
    "annotations",
    "developer-tools",
    "source-map",
    "ai-agents"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/register.js",
    "./dist/register.cjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./register": {
      "import": {
        "types": "./dist/register.d.ts",
        "default": "./dist/register.js"
      },
      "require": {
        "types": "./dist/register.d.cts",
        "default": "./dist/register.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "example:install": "pnpm --dir examples/vite-react install",
    "example:build": "pnpm --dir examples/vite-react run build",
    "pack:dry-run": "pnpm pack --dry-run",
    "check:all": "pnpm run check && pnpm run example:build && pnpm run pack:dry-run && pnpm run semgrep",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run check:all && changeset publish",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run check:all",
    "prepare": "husky",
    "preinstall": "node -e \"if (!process.env.npm_execpath?.includes('pnpm')) { console.error('Use pnpm'); process.exit(1) }\"",
    "semgrep": "semgrep scan --config .puli/semgrep --error",
    "semgrep:sarif": "semgrep scan --config .puli/semgrep --sarif --output semgrep.sarif --error"
  },
  "dependencies": {
    "bippy": "^0.5.39",
    "element-source": "^0.0.5",
    "sonner": "^2.0.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "fallow": "^2.75.0",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "packageManager": "pnpm@11.1.3"
}
