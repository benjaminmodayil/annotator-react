{
  "name": "@miku/annotator-react",
  "version": "0.1.0",
  "description": "React overlay for source-aware UI annotations copied into coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "Benjamin Modayil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miku/annotator-react.git"
  },
  "homepage": "https://github.com/miku/annotator-react#readme",
  "bugs": {
    "url": "https://github.com/miku/annotator-react/issues"
  },
  "keywords": [
    "react",
    "vite",
    "annotations",
    "developer-tools",
    "source-map",
    "ai-agents"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/register.js",
    "./dist/register.cjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./register": {
      "import": {
        "types": "./dist/register.d.ts",
        "default": "./dist/register.js"
      },
      "require": {
        "types": "./dist/register.d.cts",
        "default": "./dist/register.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build",
    "example:install": "npm install --prefix examples/vite-react",
    "example:build": "npm run build --prefix examples/vite-react",
    "pack:dry-run": "npm pack --dry-run",
    "check:all": "npm run check && npm run example:build && npm run pack:dry-run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run check:all && changeset publish",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check:all"
  },
  "dependencies": {
    "bippy": "^0.5.39",
    "element-source": "^0.0.5",
    "sonner": "^2.0.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "happy-dom": "^20.0.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
