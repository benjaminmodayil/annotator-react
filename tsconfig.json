{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@mikuexe/annotator-react": ["./src/index.ts"],
      "@mikuexe/annotator-react/register": ["./src/register.ts"]
    },
    "jsx": "react-jsx"
  },
  "include": [
    ".puli/**/*.mjs",
    "eslint.config.mjs",
    "examples/vite-react/src",
    "examples/vite-react/vite.config.ts",
    "scripts/**/*.mjs",
    "src",
    "tsup.config.ts",
    "vitest.config.ts"
  ]
}
